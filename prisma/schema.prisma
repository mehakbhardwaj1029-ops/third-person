generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStage {
  UPLOADED

  CHUNK_ANALYSIS
  CHUNK_ANALYZED

  BEHAVIOR_EVOLUTION
  BEHAVIOR_EVOLVED

  FINAL_SYNTHESIS

  COMPLETED

  BLOCKED
  FAILED
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  password          String
  createdAt         DateTime @default(now())
  chats             Chat[]

  @@map("users")
}

model Chat {
  id                  String @id @default(cuid())
  userId              String
  user                User   @relation(fields: [userId], references: [id])

  fileHash            String
  conversationHash    String
  resumeFromChunk Int @default(1)
  ancestorFileHash String?

  title               String @default("Untitled Chat")

  rawText             String @db.Text

  fileUrl             String?
  parsedJson          Json?

  tone                String @default("COACH")
  status              String @default("UPLOADED")

  sourceApp           String
  messageCount        Int
  participants        String[]
  userParticipant     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  analysis            ChatAnalysis?
  chatParticipants    ChatParticipant[]
  participantAnalysis ParticipantAnalysis[]
  @@index([userId])
  @@index([fileHash])
  @@index([conversationHash])
  @@map("file_chats")
}

model ChatAnalysis {
  id                   String   @id @default(cuid())
  chatId               String   @unique
  fileHash             String
  chat                 Chat     @relation(fields: [chatId], references: [id])
  summary              String?  @db.Text
  compatibilityScore   Int
  userInsights         Json
  overallInsights      Json
  tone                 String
  createdAt            DateTime @default(now())

  @@index([chatId])
  @@map("chat_analyses")
}

model Participant {
  id                    String                @id @default(cuid())
  name                  String
  userId                String
  chats                 ChatParticipant[]
  createdAt             DateTime              @default(now())
  analyses              ParticipantAnalysis[]

  @@unique([userId, name])
  @@index([userId])
  @@map("participants")
}

model ChatParticipant {
  id                      String @id @default(cuid())
  chatId                  String
  participantId           String

  chat                    Chat        @relation(fields: [chatId], references: [id])
  participant             Participant @relation(fields: [participantId], references: [id])

  @@unique([chatId, participantId], name: "chatId_participantId")
  @@map("chat_participants")
}

model ParticipantAnalysis {
  id                      String      @id @default(cuid())
  chatId                  String
  chat                    Chat        @relation(fields: [chatId], references: [id])
  participantId           String
  participant             Participant @relation(fields: [participantId], references: [id])
  traits                  Json
  emotions                Json
  mbtiType                String
  mbtiMeta                Json
  behaviourPatterns       Json
  createdAt               DateTime    @default(now())

  @@index([chatId])
  @@unique([chatId, participantId], name: "chatId_participantId")
  @@map("participant_analyses")
}

model Chunk{
  id                       String   @id @default(cuid())
  fileHash                 String   
  conversationHash         String
  order                    Int
  content                  String   @db.Text
  chunkHash                String   
  status                   String   @default("READY")
  summary                  Json?
  embeddingId              String?
  tokenCount               Int?
  createdAt                DateTime @default(now())

  @@unique([fileHash, order])
  @@index([conversationHash])
  @@index([chunkHash])
  @@map("chunk")
}


model ChatProcessingState {
  id                       String @id @default(cuid())

  fileHash                 String @unique

  conversationHash         String

  totalChunks              Int

  currentStage             AnalysisStage

  lastChunkSummarized      Int @default(0)

  lastChunkBehaviorEvolved Int @default(0)

  finalAnalysisGenerated   Boolean @default(false)

  recoverableError         Json?

  messageCount             Int

  createdAt                DateTime @default(now())

  updatedAt                DateTime @updatedAt

  @@index([conversationHash])
  @@map("chat_processing_state")
}


model BehavioralState {
  id                         String   @id @default(cuid())

  fileHash                   String   @unique

  conversationHash           String

  state                      Json


  analysisVersion            Int @default(1)

  updatedAt                  DateTime @updatedAt

  createdAt                  DateTime @default(now())

  @@index([conversationHash])

  @@map("behavioral_state")
}